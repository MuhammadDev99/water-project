{
  "name": "create-t3-turbo",
  "private": true,
  "engines": {
    "node": "^24.11.0",
    "pnpm": "^10.19.0"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "push": "git add . & git commit -m \"Update\" & git push origin main",
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "pnpm -F @water/auth generate",
    "db:push": "pnpm --filter @water/db push",
    "db:studio": "pnpm --filter @water/db studio",
    "db:seed": "pnpm --filter @water/db seed",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @water/nextjs...",
    "dev:client": "pnpm --filter @water/expo-client dev",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@turbo/gen": "^2.5.8",
    "@water/prettier-config": "workspace:*",
    "dotenv-cli": "^10.0.0",
    "prettier": "catalog:",
    "turbo": "^2.5.8",
    "typescript": "catalog:"
  },
  "prettier": "@water/prettier-config"
}
